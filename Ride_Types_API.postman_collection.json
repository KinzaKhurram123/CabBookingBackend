{
  "info": {
    "name": "Ride Types API",
    "description": "Admin CRUD operations for managing ride types (vehicle categories) with pricing",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "adminToken",
      "value": "YOUR_ADMIN_TOKEN_HERE",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "User - Get All Ride Types",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/ride-types",
          "host": ["{{baseUrl}}"],
          "path": ["api", "ride-types"]
        },
        "description": "Get all active ride types grouped by category (public endpoint)"
      }
    },
    {
      "name": "Admin - Get All Ride Types",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/admin/ride-types?page=1&limit=20",
          "host": ["{{baseUrl}}"],
          "path": ["api", "admin", "ride-types"],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "limit",
              "value": "20"
            },
            {
              "key": "category",
              "value": "standard",
              "disabled": true
            },
            {
              "key": "isActive",
              "value": "true",
              "disabled": true
            }
          ]
        },
        "description": "Get all ride types with pagination and filters (admin only)"
      }
    },
    {
      "name": "Admin - Get Single Ride Type",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/admin/ride-types/:id",
          "host": ["{{baseUrl}}"],
          "path": ["api", "admin", "ride-types", ":id"],
          "variable": [
            {
              "key": "id",
              "value": "RIDE_TYPE_ID_HERE"
            }
          ]
        },
        "description": "Get single ride type by ID"
      }
    },
    {
      "name": "Admin - Create Ride Type (Lynk X)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"category\": \"standard\",\n  \"categoryDisplayName\": \"Lynk Standard\",\n  \"categoryDescription\": \"Standard rides for everyday commuting\",\n  \"categoryIcon\": \"local-taxi\",\n  \"categoryColor\": \"#2196F3\",\n  \"rideId\": \"lynk_x\",\n  \"name\": \"Lynk X\",\n  \"description\": \"Budget-friendly everyday rides\",\n  \"features\": [\n    \"Budget-friendly\",\n    \"Everyday rides\",\n    \"Comfortable seating\"\n  ],\n  \"priceModel\": \"varies\",\n  \"basePrice\": 50,\n  \"pricePerKm\": 12,\n  \"pricePerMin\": 1.5,\n  \"capacity\": 4,\n  \"luggageCapacity\": 2,\n  \"timeEstimate\": \"Real time in Minutes, wait time\",\n  \"icon\": \"car\",\n  \"isActive\": true,\n  \"order\": 1\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/admin/ride-types",
          "host": ["{{baseUrl}}"],
          "path": ["api", "admin", "ride-types"]
        },
        "description": "Create new ride type - Lynk X (Standard)"
      }
    },
    {
      "name": "Admin - Create Ride Type (Lynk Plus)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"category\": \"standard\",\n  \"categoryDisplayName\": \"Lynk Standard\",\n  \"categoryDescription\": \"Standard rides for everyday commuting\",\n  \"categoryIcon\": \"local-taxi\",\n  \"categoryColor\": \"#2196F3\",\n  \"rideId\": \"lynk_plus\",\n  \"name\": \"Lynk Plus\",\n  \"description\": \"Spacious, newer vehicles with extra comfort\",\n  \"features\": [\n    \"Spacious\",\n    \"Newer vehicles\",\n    \"Extra comfort\",\n    \"Professional drivers\"\n  ],\n  \"priceModel\": \"varies\",\n  \"basePrice\": 80,\n  \"pricePerKm\": 18,\n  \"pricePerMin\": 2,\n  \"capacity\": 4,\n  \"luggageCapacity\": 3,\n  \"timeEstimate\": \"Real time in Minutes, wait time\",\n  \"icon\": \"car\",\n  \"isActive\": true,\n  \"order\": 2\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/admin/ride-types",
          "host": ["{{baseUrl}}"],
          "path": ["api", "admin", "ride-types"]
        },
        "description": "Create new ride type - Lynk Plus (Standard)"
      }
    },
    {
      "name": "Admin - Create Ride Type (Lynk SUV)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"category\": \"premium\",\n  \"categoryDisplayName\": \"Lynk Premium\",\n  \"categoryDescription\": \"Premium luxury rides for special occasions\",\n  \"categoryIcon\": \"stars\",\n  \"categoryColor\": \"#FF9800\",\n  \"rideId\": \"lynk_suv\",\n  \"name\": \"Lynk SUV\",\n  \"description\": \"High-end luxury rides with professional drivers\",\n  \"features\": [\n    \"High-end luxury\",\n    \"Professional drivers\",\n    \"Premium comfort\",\n    \"VIP service\"\n  ],\n  \"priceModel\": \"varies\",\n  \"basePrice\": 150,\n  \"pricePerKm\": 30,\n  \"pricePerMin\": 3.5,\n  \"capacity\": 6,\n  \"luggageCapacity\": 4,\n  \"timeEstimate\": \"Real time in Minutes, wait time\",\n  \"icon\": \"car\",\n  \"isActive\": true,\n  \"order\": 1\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/admin/ride-types",
          "host": ["{{baseUrl}}"],
          "path": ["api", "admin", "ride-types"]
        },
        "description": "Create new ride type - Lynk SUV (Premium)"
      }
    },
    {
      "name": "Admin - Update Ride Type",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"basePrice\": 60,\n  \"pricePerKm\": 15,\n  \"pricePerMin\": 2,\n  \"description\": \"Updated description\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/admin/ride-types/:id",
          "host": ["{{baseUrl}}"],
          "path": ["api", "admin", "ride-types", ":id"],
          "variable": [
            {
              "key": "id",
              "value": "RIDE_TYPE_ID_HERE"
            }
          ]
        },
        "description": "Update ride type pricing and details"
      }
    },
    {
      "name": "Admin - Toggle Active Status",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/admin/ride-types/:id/toggle",
          "host": ["{{baseUrl}}"],
          "path": ["api", "admin", "ride-types", ":id", "toggle"],
          "variable": [
            {
              "key": "id",
              "value": "RIDE_TYPE_ID_HERE"
            }
          ]
        },
        "description": "Toggle ride type active/inactive status"
      }
    },
    {
      "name": "Admin - Delete Ride Type",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/admin/ride-types/:id",
          "host": ["{{baseUrl}}"],
          "path": ["api", "admin", "ride-types", ":id"],
          "variable": [
            {
              "key": "id",
              "value": "RIDE_TYPE_ID_HERE"
            }
          ]
        },
        "description": "Delete ride type permanently"
      }
    }
  ]
}
