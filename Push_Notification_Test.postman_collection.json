{
  "info": {
    "name": "Push Notification Test",
    "description": "Test push notifications for RideLynk app",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Login User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"your_email@example.com\",\n  \"password\": \"your_password\"\n}"
        },
        "url": {
          "raw": "{{BASE_URL}}/api/auth/login",
          "host": ["{{BASE_URL}}"],
          "path": ["api", "auth", "login"]
        }
      },
      "response": []
    },
    {
      "name": "2. Register FCM Token",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{AUTH_TOKEN}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"token\": \"eeUWgSHpQBOVshOPWDiN37:APA91bEMSIGrL2tFE29DuMj0eeTwKA_YnG83p4AjUfItD3TZz3dnDthS0Skf73MB_m3sh3gs1H_vE5OjkD8jHo56fzylWwO0pVk-tt7xLPwl3OK8-LYryJcLOG\",\n  \"deviceType\": \"android\",\n  \"deviceId\": \"test_device_123\"\n}"
        },
        "url": {
          "raw": "{{BASE_URL}}/api/users/fcm-token",
          "host": ["{{BASE_URL}}"],
          "path": ["api", "users", "fcm-token"]
        }
      },
      "response": []
    },
    {
      "name": "3. Send Test Notification",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{AUTH_TOKEN}}"
          }
        ],
        "url": {
          "raw": "{{BASE_URL}}/api/notifications/test",
          "host": ["{{BASE_URL}}"],
          "path": ["api", "notifications", "test"]
        }
      },
      "response": []
    },
    {
      "name": "4. Get All Notifications",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{AUTH_TOKEN}}"
          }
        ],
        "url": {
          "raw": "{{BASE_URL}}/api/notifications",
          "host": ["{{BASE_URL}}"],
          "path": ["api", "notifications"]
        }
      },
      "response": []
    },
    {
      "name": "5. Check Unread Count",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{AUTH_TOKEN}}"
          }
        ],
        "url": {
          "raw": "{{BASE_URL}}/api/notifications/unread-count",
          "host": ["{{BASE_URL}}"],
          "path": ["api", "notifications", "unread-count"]
        }
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "BASE_URL",
      "value": "https://krystal-imaginable-hurtlingly.ngrok-free.dev",
      "type": "string"
    },
    {
      "key": "AUTH_TOKEN",
      "value": "your_auth_token_here",
      "type": "string"
    }
  ]
}
